<svg xmlns="http://www.w3.org/2000/svg" width="1180" height="560" viewBox="0 0 1180 560" role="img" aria-labelledby="title desc">
  <title id="title">实验 7 单臂路由、NAT 与 ACL 链路流程图</title>
  <desc id="desc">从 PC0 所在 VLAN 19 进入路由器 0 子接口，经过 NAT 路由器到右侧路由器 3，再进入 VLAN 50 或 VLAN 37。ACL 放在路由器 0 的 fa0/0.19 入方向。</desc>
  <defs>
    <marker id="arrow" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto" markerUnits="strokeWidth">
      <path d="M0,0 L0,6 L9,3 z" fill="#2f4858" />
    </marker>
    <style>
      .bg { fill: #f7f9fb; }
      .zone { fill: #ffffff; stroke: #d5dde5; stroke-width: 2; rx: 10; }
      .device { fill: #e7f1ff; stroke: #2f6f9f; stroke-width: 2; rx: 8; }
      .switch { fill: #eaf7ef; stroke: #3d8b57; stroke-width: 2; rx: 8; }
      .router { fill: #fff1d6; stroke: #b7791f; stroke-width: 2; rx: 8; }
      .acl { fill: #ffe7e2; stroke: #c2410c; stroke-width: 2; rx: 8; }
      .nat { fill: #f0e9ff; stroke: #6d28d9; stroke-width: 2; rx: 8; }
      .line { stroke: #2f4858; stroke-width: 3; fill: none; marker-end: url(#arrow); }
      .dash { stroke-dasharray: 8 6; }
      .label { font: 16px "Microsoft YaHei", "Noto Sans CJK SC", Arial, sans-serif; fill: #1f2933; }
      .small { font: 13px "Microsoft YaHei", "Noto Sans CJK SC", Arial, sans-serif; fill: #52606d; }
      .title { font: 20px "Microsoft YaHei", "Noto Sans CJK SC", Arial, sans-serif; font-weight: 700; fill: #102a43; }
      .mono { font: 13px Consolas, "Microsoft YaHei", monospace; fill: #243b53; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="1180" height="560"/>

  <rect class="zone" x="30" y="40" width="320" height="450"/>
  <text class="title" x="55" y="75">左侧 VLAN 区</text>
  <rect class="device" x="70" y="125" width="110" height="74"/>
  <text class="label" x="98" y="154">PC0</text>
  <text class="small" x="83" y="180">192.168.19.1</text>
  <rect class="device" x="70" y="280" width="110" height="74"/>
  <text class="label" x="98" y="309">PC1</text>
  <text class="small" x="83" y="335">192.168.20.1</text>
  <rect class="switch" x="220" y="205" width="100" height="84"/>
  <text class="label" x="238" y="238">Switch0</text>
  <text class="small" x="236" y="263">fa0/1 trunk</text>

  <rect class="zone" x="395" y="40" width="350" height="450"/>
  <text class="title" x="420" y="75">中间路由/NAT</text>
  <rect class="router" x="425" y="205" width="120" height="88"/>
  <text class="label" x="455" y="237">Router0</text>
  <text class="mono" x="438" y="263">fa0/0.19</text>
  <text class="mono" x="438" y="282">fa0/0.20</text>
  <rect class="acl" x="415" y="115" width="140" height="62"/>
  <text class="label" x="443" y="142">ACL 入口</text>
  <text class="small" x="428" y="164">fa0/0.19 in</text>
  <rect class="nat" x="590" y="205" width="120" height="88"/>
  <text class="label" x="620" y="237">Router1</text>
  <text class="small" x="612" y="262">NAT 路由器</text>
  <text class="mono" x="603" y="282">fa0/0 / fa0/1</text>

  <rect class="zone" x="790" y="40" width="360" height="450"/>
  <text class="title" x="815" y="75">右侧 VLAN 区</text>
  <rect class="router" x="820" y="205" width="120" height="88"/>
  <text class="label" x="850" y="237">Router3</text>
  <text class="mono" x="833" y="263">fa0/1.50</text>
  <text class="mono" x="833" y="282">fa0/1.37</text>
  <rect class="switch" x="990" y="205" width="100" height="84"/>
  <text class="label" x="1008" y="238">Switch2</text>
  <text class="small" x="1006" y="263">trunk 上联</text>
  <rect class="device" x="1010" y="105" width="110" height="74"/>
  <text class="label" x="1038" y="134">PC4</text>
  <text class="small" x="1020" y="160">174.50.0.1</text>
  <rect class="device" x="1010" y="315" width="110" height="74"/>
  <text class="label" x="1038" y="344">PC5</text>
  <text class="small" x="1020" y="370">174.37.0.1</text>

  <path class="line" d="M180 162 C200 162, 205 230, 220 230"/>
  <path class="line" d="M180 317 C200 317, 205 265, 220 265"/>
  <path class="line" d="M320 247 L425 247"/>
  <path class="line" d="M545 247 L590 247"/>
  <path class="line" d="M710 247 L820 247"/>
  <path class="line" d="M940 247 L990 247"/>
  <path class="line" d="M1090 230 C1110 210, 1110 175, 1120 160"/>
  <path class="line" d="M1090 265 C1110 285, 1110 320, 1120 337"/>
  <path class="line dash" d="M485 177 L485 205"/>

  <text class="small" x="194" y="128">Access: VLAN 19</text>
  <text class="small" x="192" y="365">Access: VLAN 20</text>
  <text class="small" x="344" y="230">802.1Q trunk</text>
  <text class="small" x="560" y="232">192.168.21.0/24</text>
  <text class="small" x="737" y="232">174.1.1.0/16</text>
  <text class="small" x="948" y="230">802.1Q trunk</text>

  <rect class="zone" x="70" y="505" width="1040" height="36"/>
  <text class="small" x="92" y="528">PC0 发包路径：PC0 -> Switch0 access 口 -> trunk -> Router0 fa0/0.19 入方向匹配 ACL -> Router0/R1/R3 路由与 NAT -> 右侧子接口 -> Switch2 -> PC4/PC5</text>
</svg>
